# Reverse proxy unique point d'entrée.
# DEV  : sites en `http://…` (port 80, pas de TLS) → test via en-tête Host sur 8090.
# PROD : surcharger {$*_SITE} avec le domaine nu (ex. `yohan-debusscher.com`) → Caddy
#        sert en HTTPS (:443) avec certificats Let's Encrypt automatiques.

{
	admin off
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

# CSP : `unsafe-inline` requis par les scripts/styles inline de Next (pas de nonce
# sans middleware dédié). {$MEDIA_ORIGIN} = origine publique des images (dev :
# http://localhost:9100 ; prod : vide, /media/* est même origine → 'self' suffit).
(csp_web) {
	header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' {$STATS_SITE:http://stats.yohan-debusscher.com}; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: {$MEDIA_ORIGIN:}; font-src 'self' data:; connect-src 'self' {$STATS_SITE:http://stats.yohan-debusscher.com}; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
}

(csp_admin) {
	# img-src https: — avatars externes (MinIO public, Microsoft Graph).
	header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: {$MEDIA_ORIGIN:}; font-src 'self' data:; connect-src 'self'; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
}

# Site public + médias (bucket public MinIO sous /media/*)
{$WEB_SITE:http://yohan-debusscher.com} {
	import security_headers
	import csp_web
	handle /media/* {
		reverse_proxy minio:9000
	}
	handle {
		# X-Real-IP écrasé (jamais relayé du client) → IP de confiance pour le
		# rate-limit applicatif ; X-Forwarded-For reste spoofable (append).
		reverse_proxy web:3100 {
			header_up X-Real-IP {client_ip}
		}
	}
}

# Back office
{$ADMIN_SITE:http://bo.yohan-debusscher.com} {
	import security_headers
	import csp_admin
	# Surfaces internes — jamais exposées publiquement. Défense en profondeur :
	# Caddy les bloque, et l'app exige leurs tokens dédiés.
	# - /internal/*     : rendu CV (cv-renderer, CV_RENDER_TOKEN)
	# - /api/internal/* : API booking web→admin (APPOINTMENTS_INTERNAL_TOKEN)
	handle /internal/* {
		respond 404
	}
	handle /api/internal/* {
		respond 404
	}
	handle {
		reverse_proxy admin:3101 {
			header_up X-Real-IP {client_ip}
		}
	}
}

# Statistiques (Umami : collecte publique + dashboard derrière son auth)
{$STATS_SITE:http://stats.yohan-debusscher.com} {
	import security_headers
	reverse_proxy umami:3000
}
