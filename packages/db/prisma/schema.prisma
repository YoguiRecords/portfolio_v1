// Prisma 7 — nouveau générateur `prisma-client` (ESM, output requis).
// Le client généré (../generated/prisma) est git-ignoré ; régénérer via `pnpm --filter @portfolio/db db:generate`.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

// ──────────────────────────────────────────────────────────────────────────
// Identité du site (À propos / CV)
// ──────────────────────────────────────────────────────────────────────────

/// Profil unique du portfolio (une seule ligne, contrainte applicative).
model Profile {
  id       String  @id @default(cuid())
  fullName String
  headline String
  bio      String // markdown
  email    String
  location String?
  cvPdfUrl String? // PDF du CV (téléchargement)
  cvHtml   String? // CV complet en HTML (mise en page premium), éditable au BO

  avatarId String?     @unique
  avatar   MediaAsset? @relation("ProfileAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  socials SocialLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id    String  @id @default(cuid())
  label String
  url   String
  icon  String?
  order Int     @default(0)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// ──────────────────────────────────────────────────────────────────────────
// Projets
// ──────────────────────────────────────────────────────────────────────────

model Technology {
  id   String  @id @default(cuid())
  name String  @unique
  slug String  @unique
  icon String?

  projects Project[] @relation("ProjectTechnologies")
}

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String
  content     String // markdown
  repoUrl     String?
  liveUrl     String?
  featured    Boolean       @default(false)
  status      ProjectStatus @default(DRAFT)
  publishedAt DateTime?
  order       Int           @default(0)

  coverId String?
  cover   MediaAsset? @relation("ProjectCover", fields: [coverId], references: [id], onDelete: SetNull)

  technologies Technology[]   @relation("ProjectTechnologies")
  images       ProjectImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
  @@index([order])
}

model ProjectImage {
  id    String @id @default(cuid())
  order Int    @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  imageId String
  image   MediaAsset @relation("ProjectImages", fields: [imageId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ──────────────────────────────────────────────────────────────────────────
// News / Articles
// ──────────────────────────────────────────────────────────────────────────

model Article {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String
  content        String // markdown
  tags           String[]
  featured       Boolean       @default(false)
  status         ArticleStatus @default(DRAFT)
  readingMinutes Int?
  publishedAt    DateTime?

  coverId String?
  cover   MediaAsset? @relation("ArticleCover", fields: [coverId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
}

// ──────────────────────────────────────────────────────────────────────────
// Médias (pipeline upload → webp → MinIO)
// ──────────────────────────────────────────────────────────────────────────

/// Chaque image convertie (webp) stockée dans MinIO est tracée ici.
model MediaAsset {
  id           String   @id @default(cuid())
  url          String   @unique
  alt          String?
  originalName String
  mimeType     String
  sizeBytes    Int
  width        Int
  height       Int
  createdAt    DateTime @default(now())

  // Back-relations
  profileAvatar Profile?       @relation("ProfileAvatar")
  projectCovers Project[]      @relation("ProjectCover")
  projectImages ProjectImage[] @relation("ProjectImages")
  articleCovers Article[]      @relation("ArticleCover")
}
