// Prisma 7 — nouveau générateur `prisma-client` (ESM, output requis).
// Le client généré (../generated/prisma) est git-ignoré ; régénérer via `pnpm --filter @portfolio/db db:generate`.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

/// Type de projet — pilote les blocs de fiche affichés/pré-activés au BO.
enum ProjectType {
  GAME // jeu → Game Design Document
  SOFTWARE // logiciel → Architecture & stack, Sécurité
  WEBSITE // site web → Design/UX, Perf/SEO/A11y
  BUSINESS // analyse business → SWOT/PESTEL/PORTER, recommandations
}

/// Tendance d'un KPI (flèche ▲ ▼ —).
enum TrendDirection {
  UP
  DOWN
  FLAT
}

/// Cadres d'analyse appliqués au profil humain (chapitre « Qui je suis »).
/// PESTEL/PORTER sont réservés aux fiches projet (cf. ProjectBlock ANALYSIS).
enum AnalysisType {
  SWOT // forces / faiblesses / opportunités / menaces
  FOUR_P // mix marketing : produit · prix · place · promotion
  GOLDEN_CIRCLE // why · how · what (Simon Sinek)
  IKIGAI // 4 cercles + centre
}

/// Statut d'un objectif de carrière (chapitre « Le cap »).
enum GoalStatus {
  ACHIEVED // acquis
  IN_PROGRESS // en cours
  TARGET // cible
  HORIZON // horizon
}

/// Type d'un bloc de fiche projet (flexible content). Le `data` JSON est
/// validé par Zod selon ce type (côté Server Action de l'admin).
enum ProjectBlockType {
  CONTEXT // problème · objectif · rôle
  PROCESS // démarche + frise (Gantt) d'exécution
  ANALYSIS // SWOT / PESTEL / PORTER du projet
  GAME_DESIGN // piliers · core loop · mécaniques (jeu)
  ARCHITECTURE // couches · flux · décisions (logiciel)
  SECURITY // mesures de sécurité
  DESIGN_UX // tokens · typo · parcours (site)
  METRICS // scores perf / SEO / A11y (site)
  RECOMMENDATIONS // recommandations priorisées + livrables (business)
  RESULTS // résultats / impact (stat cards)
  GALLERY // galerie de médias (cf. ProjectImage)
  TEXT // bloc texte libre (markdown)
}

/// Portée d'une entrée FAQ (rich snippet FAQPage + réponses aux moteurs IA).
enum FaqScope {
  GLOBAL
  HOME
  PROJECT
  ARTICLE
}

/// Statut de modération d'un témoignage.
enum TestimonialStatus {
  PENDING // soumis, en attente de validation
  APPROVED // validé → affiché publiquement
  REJECTED // refusé → jamais affiché
}

/// Visibilité d'un évènement de l'agenda.
enum EventVisibility {
  PUBLIC
  PRIVATE
}

/// Statut de publication d'un évènement (programmable comme les actus).
enum EventStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

/// Nature d'un média : image convertie, vidéo hébergée, ou embed externe.
enum MediaKind {
  IMAGE
  VIDEO
  EMBED
}

/// Statut d'une demande de rendez-vous (inbox BO).
enum AppointmentStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
}

/// Origine d'une demande de rendez-vous.
enum AppointmentSource {
  CONTACT
  CHATBOT
  MANUAL
}

// ──────────────────────────────────────────────────────────────────────────
// Authentification back office (compte admin unique, sessions opaques)
// ──────────────────────────────────────────────────────────────────────────

/// Rôle d'un compte BO = préréglage de modules + étiquette (cf. RBAC).
enum AdminRole {
  OWNER
  EDITOR
  SECRETARY
  VIEWER
}

/// Compte administrateur du back office (multi-utilisateurs + RBAC).
/// Auth durcie : mot de passe haché argon2id + TOTP (MFA obligatoire).
/// Ces tables ne sont JAMAIS accessibles au rôle DB public `app_web`
/// (REVOKE explicite dans la migration) — seul `app_admin` y accède.
model AdminUser {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String // argon2id (placeholder tant qu'une invitation n'est pas honorée ; compte alors isActive=false)
  totpSecret     String? // secret TOTP (base32), null tant que non enrôlé
  isTotpEnabled  Boolean   @default(false)
  failedAttempts Int       @default(0) // compteur anti brute-force
  lockedUntil    DateTime? // verrou temporaire après trop d'échecs
  lastLoginAt    DateTime?

  // RBAC multi-utilisateurs
  role        AdminRole @default(OWNER)
  permissions String[]  @default([]) // modules accordés (OWNER = tous, bypass)
  isActive    Boolean   @default(true)
  displayName String?
  createdById String? // qui a créé ce compte (auto-référence souple)

  sessions Session[]
  invites  AdminInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Invitation d'onboarding (single-use, expirable, révocable). Seul le hash du
/// token est stocké — jamais le token en clair. Pas d'inscription publique.
model AdminInvite {
  id          String    @id @default(cuid())
  email       String
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique // SHA-256 du token d'invitation
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  @@index([adminUserId])
}

/// Session opaque côté serveur : un token aléatoire est posé en cookie httpOnly,
/// seul son hash est stocké ici (le token brut n'est jamais persisté). Pas de JWT.
model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique // SHA-256 du token de session
  expiresAt  DateTime
  mfaPending Boolean  @default(false) // true = mot de passe OK, 2e facteur (TOTP) pas encore validé
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

/// Journal des tentatives de connexion (monitoring anti brute-force).
/// `email` est la valeur saisie (peut ne correspondre à aucun compte).
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────────────────
// Identité du site (À propos / CV)
// ──────────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────────
// CV — enums (corpus CV dynamique projeté sur PDF / page /cv / home)
// ──────────────────────────────────────────────────────────────────────────

enum SkillKind {
  TECH
  SOFT
}

enum ProjectCvBadge {
  NONE
  KEY
  IN_PROGRESS
}

enum ExperienceTier {
  FEATURED
  PREVIOUS
  MINI
}

enum ExperienceBadge {
  NONE
  PERSO
  EN_COURS
  CLE
}

/// Profil unique du portfolio (une seule ligne, contrainte applicative).
model Profile {
  id       String  @id @default(cuid())
  fullName String
  headline String
  bio      String // markdown
  email    String
  location String?
  cvPdfUrl String? // PDF du CV (téléchargement)
  cvHtml   String? // CV complet en HTML (mise en page premium), éditable au BO

  // Hero / accroche (chapitre d'ouverture)
  typewriterLines   String[] // phrases qui se tapent (« Je conçois… », « Je pilote… »)
  sigText           String? // indicateur vert mono (« vision · management · exécution »)
  isAvailable       Boolean  @default(true) // statut de disponibilité
  availabilityLabel String? // ex. « Disponible · ouvert aux missions »
  currentRole       String? // nœud « Aujourd'hui » du parcours (« Indépendant · fondateur »)

  // Découvrabilité (SEO + moteurs IA / AEO)
  aiSummary String? // résumé court « quotable » par les IA (« Qui est Yohan ? »)

  // CV (champs spécifiques au document CV / page /cv)
  cvAccroche          String? // accroche éditoriale du CV
  cvAvailabilityStart String? // « Prise de poste » (ex. « Immédiate »)
  cvMobility          String? // « Mobilité » (ex. « Hauts-de-France · remote »)
  cvContractType      String? // « Contrat » (ex. « CDI · freelance »)

  avatarId String?     @unique
  avatar   MediaAsset? @relation("ProfileAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  socials SocialLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id    String  @id @default(cuid())
  label String
  url   String
  icon  String?
  order Int     @default(0)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

/// Expérience professionnelle (corpus CV). Projetée sur PDF (condensé),
/// page /cv (détaillé) et éventuellement la home, selon les drapeaux.
model Experience {
  id           String          @id @default(cuid())
  title        String
  company      String
  location     String?
  startDate    DateTime
  endDate      DateTime? // null = poste en cours
  tier         ExperienceTier  @default(MINI)
  badge        ExperienceBadge @default(NONE)
  stack        String[] // tags techno (CV)
  bullets      String[] // puces de réalisations (CV condensé)
  description  String? // texte long — page /cv uniquement
  order        Int             @default(0)
  showOnPdf    Boolean         @default(false)
  showOnCvPage Boolean         @default(true)
  showOnSite   Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([order])
  @@index([startDate])
}

/// Formation (chapitre « Formations » du CV).
model Education {
  id           String   @id @default(cuid())
  title        String
  institution  String?
  date         String // libellé (« 2018 — 2020 »)
  details      String[] // sous-lignes
  order        Int      @default(0)
  showOnPdf    Boolean  @default(true)
  showOnCvPage Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([order])
}

/// Langue (sidebar CV).
model Language {
  id        String   @id @default(cuid())
  name      String // « Français »
  level     String // « Langue maternelle », « C1 »
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// Centre d'intérêt (sidebar CV).
model Interest {
  id        String   @id @default(cuid())
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// PDF du CV généré par le BO, une ligne par langue (upsert). Servi figé au public.
model CvExport {
  id          String   @id @default(cuid())
  locale      String   @unique // « fr » | « en »
  url         String // URL MinIO publique
  sizeBytes   Int
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────────
// Projets
// ──────────────────────────────────────────────────────────────────────────

model Technology {
  id   String  @id @default(cuid())
  name String  @unique
  slug String  @unique
  icon String?

  projects Project[] @relation("ProjectTechnologies")
}

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String
  content     String // markdown
  repoUrl     String?
  liveUrl     String?
  featured    Boolean       @default(false)
  status      ProjectStatus @default(DRAFT)
  publishedAt DateTime?
  order       Int           @default(0)

  // CV — « Réalisations » (cartes, badges)
  showOnCv Boolean        @default(false)
  cvBadge  ProjectCvBadge @default(NONE)

  // Fiche « étude de cas » — entête + blocs modulaires selon le type
  type        ProjectType @default(SOFTWARE)
  role        String? // ex. « Lead technique », « Consultant »
  periodLabel String? // ex. « 2023 — 2024 » (affichage)
  startDate   DateTime? // tri chronologique + JSON-LD
  endDate     DateTime?
  statusLabel String? // ex. « En production »
  tagline     String? // accroche (standfirst) de la fiche
  sigText     String? // indicateur vert (« conçu · piloté · livré »)

  // SEO & découvrabilité (Open Graph + JSON-LD CreativeWork + AEO)
  seoTitle       String?
  seoDescription String?
  aiSummary      String? // résumé quotable par les moteurs IA
  ogImageId      String?
  ogImage        MediaAsset? @relation("ProjectOg", fields: [ogImageId], references: [id], onDelete: SetNull)

  coverId String?
  cover   MediaAsset? @relation("ProjectCover", fields: [coverId], references: [id], onDelete: SetNull)

  technologies Technology[]   @relation("ProjectTechnologies")
  images       ProjectImage[]
  links        ProjectLink[]
  blocks       ProjectBlock[]
  faqs         FaqEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
  @@index([order])
}

model ProjectImage {
  id    String @id @default(cuid())
  order Int    @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  imageId String
  image   MediaAsset @relation("ProjectImages", fields: [imageId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// Lien externe d'un projet (Repo, Démo, Store, Documentation, Vidéo…),
/// en plus de repoUrl/liveUrl. Ajoutable & réordonnable au BO.
model ProjectLink {
  id    String  @id @default(cuid())
  label String
  url   String
  icon  String?
  order Int     @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ──────────────────────────────────────────────────────────────────────────
// News / Articles
// ──────────────────────────────────────────────────────────────────────────

model Article {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String
  content        String // markdown
  tags           String[]
  featured       Boolean       @default(false)
  status         ArticleStatus @default(DRAFT)
  readingMinutes Int?
  publishedAt    DateTime?
  scheduledAt    DateTime? // créneau de publication programmée (status SCHEDULED)

  // SEO & découvrabilité (Open Graph + JSON-LD Article + AEO)
  seoTitle       String?
  seoDescription String?
  aiSummary      String? // résumé quotable par les moteurs IA
  ogImageId      String?
  ogImage        MediaAsset? @relation("ArticleOg", fields: [ogImageId], references: [id], onDelete: SetNull)

  coverId String?
  cover   MediaAsset? @relation("ArticleCover", fields: [coverId], references: [id], onDelete: SetNull)

  // Actu générée depuis un évènement de l'agenda (optionnel)
  eventId String? @unique
  event   Event?  @relation("ArticleFromEvent", fields: [eventId], references: [id], onDelete: SetNull)

  media ArticleMedia[]
  faqs  FaqEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([featured])
}

// ──────────────────────────────────────────────────────────────────────────
// Réglages, SEO & découvrabilité (SEO classique + Schema.org + GEO/AEO)
// ──────────────────────────────────────────────────────────────────────────

/// Réglages globaux du site (singleton — une seule ligne, contrainte applicative).
model SiteSettings {
  id        String  @id @default(cuid())
  brandName String? // « Yohan. » (nav)
  siteName  String? // pour <title> / SEO

  // SEO par défaut + Open Graph / Twitter Cards
  defaultSeoTitle       String?
  defaultSeoDescription String?
  twitterHandle         String?
  ogImageId             String?     @unique
  ogImage               MediaAsset? @relation("SiteOg", fields: [ogImageId], references: [id], onDelete: SetNull)

  // Footer
  footerHeadline  String? // « La suite s'écrit ensemble. »
  footerSignature String? // « Vision · management · exécution »

  // Contact
  contactEmail         String? // destinataire du formulaire (défaut : Profile.email)
  isContactFormEnabled Boolean @default(true)
  availabilityBanner   String?

  // Découvrabilité moderne (GEO/AEO, robots, vérifications, analytics)
  allowAiCrawlers    Boolean @default(true) // GPTBot, ClaudeBot, PerplexityBot…
  llmsTxt            String? // contenu servi sur /llms.txt (présentation pour les IA)
  robotsExtra        String? // directives robots.txt additionnelles
  searchConsoleToken String? // vérification Google Search Console
  umamiWebsiteId     String? // analytics (cookieless)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Section éditoriale de la home : rend titres / intros / CTA / ordre / visibilité
/// pilotables au BO (le squelette reste au code, la copy vient d'ici).
model HomeSection {
  id        String  @id @default(cuid())
  key       String  @unique // « hero », « profil », « ecosysteme », « parcours », « cap », « projets », « footer »
  navLabel  String? // libellé dans la navigation
  eyebrow   String? // marqueur (« Chapitre 01 — Qui je suis »)
  title     String? // titre (« Le profil, en clair. »)
  intro     String? // paragraphe d'introduction
  ctaLabel  String?
  ctaHref   String?
  ctaLabel2 String?
  ctaHref2  String?
  order     Int     @default(0)
  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// Entrée FAQ — alimente le rich snippet FAQPage (SEO) ET les réponses citées
/// par les moteurs IA (AEO). Globale, home, ou rattachée à un projet/article.
model FaqEntry {
  id        String   @id @default(cuid())
  question  String
  answer    String // markdown
  scope     FaqScope @default(GLOBAL)
  order     Int      @default(0)
  isVisible Boolean  @default(true)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, order])
  @@index([projectId])
  @@index([articleId])
}

// ──────────────────────────────────────────────────────────────────────────
// Contact (formulaire public → boîte de réception au BO)
// ──────────────────────────────────────────────────────────────────────────

/// Message reçu via le formulaire de contact. Validation Zod + rate-limit +
/// honeypot côté Route Handler (anti-spam). Jamais exposé au rôle DB `app_web`.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  isSpam    Boolean  @default(false)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([isRead])
}

/// Témoignage soumis publiquement, **modéré au BO avant tout affichage**.
/// `submittedContent` = texte original reçu (immuable, audit) ; `content` =
/// version affichée, éditable par l'admin. L'admin peut accepter / refuser /
/// éditer (cf. `status`). Sécurité (migration) : `app_web` peut INSÉRER un
/// témoignage mais ne peut LIRE que les colonnes d'affichage des entrées — ni
/// e-mail, ni IP, ni texte original — et ne peut PAS définir `status`
/// (→ toujours PENDING, pas d'auto-validation).
/// Lien hiérarchique de l'auteur d'un témoignage avec Yohan.
enum TestimonialRelationship {
  MANAGER // a été mon manager / supérieur
  PEER // collègue / pair
  REPORT // a été sous ma responsabilité
  CLIENT // client
  PARTNER // partenaire / prestataire
  TEACHER // professeur / formateur
  STUDENT // élève / apprenant
  OTHER
}

model Testimonial {
  id                 String                   @id @default(cuid())
  authorName         String
  authorRole         String? // « CTO », « Lead Dev »…
  authorCompany      String? // entreprise / organisation
  authorRelationship TestimonialRelationship? // lien hiérarchique avec Yohan
  authorEmail        String? // non public — vérification / reprise de contact
  content            String // version affichée (éditable au BO)
  submittedContent   String // texte original soumis (audit)
  rating             Int? // note optionnelle (1–5)
  status             TestimonialStatus        @default(PENDING)
  isFeatured         Boolean                  @default(false)
  order              Int                      @default(0)
  ip                 String?
  userAgent          String?

  avatarId String?
  avatar   MediaAsset? @relation("TestimonialAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  approvedAt DateTime?

  @@index([status, order])
}

// ──────────────────────────────────────────────────────────────────────────
// Contenu éditorial de la page d'accueil (1 portfolio → listes globales)
// ──────────────────────────────────────────────────────────────────────────

/// Indicateur chiffré du profil (Expérience, Périmètre, Management…).
model Kpi {
  id        String          @id @default(cuid())
  label     String // « Expérience »
  value     String // « 4 ans », « Tech + Business »
  note      String? // sous-texte (« en hausse »)
  trend     TrendDirection?
  order     Int             @default(0)
  isVisible Boolean         @default(true)
  showOnCv  Boolean         @default(false) // CV « En chiffres »
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([order])
}

/// Compétence affichée dans l'« écosystème » (orbit) et réutilisable ailleurs.
/// Sert aussi le CV : `kind` distingue compétences (TECH) et soft skills (SOFT),
/// `category` regroupe les TECH, `showOnCv` projette sur le CV.
model Skill {
  id        String    @id @default(cuid())
  name      String // « Full-stack », « Management », « Sécurité »
  category  String? // regroupement libre (« Compétence », « Outil » ; catégories CV pour les TECH)
  kind      SkillKind @default(TECH)
  showOnCv  Boolean   @default(false)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([order])
}

/// Voie du parcours (chapitre « La trajectoire ») — Dev, Pédagogie, Management, Business.
model CareerTrack {
  id       String @id @default(cuid())
  name     String
  slug     String @unique
  colorHex String // couleur de la voie (ex. « #f0a800 »)
  order    Int    @default(0)

  milestones CareerMilestone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// Jalon de carrière, positionné par année sur l'axe temporel.
model CareerMilestone {
  id          String  @id @default(cuid())
  dateLabel   String // « 2019 », « 2024+ »
  sortYear    Int? // pour le placement sur l'axe + tri
  role        String // « Développeur », « Directeur adjoint d'école »
  description String?
  order       Int     @default(0)

  trackId String
  track   CareerTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trackId])
  @@index([sortYear])
}

/// Objectif de carrière (chapitre « Le cap ») : rôle visé + statut.
model CareerGoal {
  id        String     @id @default(cuid())
  role      String // « Manager », « CTO », « CEO »
  status    GoalStatus @default(TARGET)
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([order])
}

/// Cadre d'analyse du profil (une SWOT, une 4P, une Golden Circle, une Ikigai).
/// Le contenu (`data`) est un JSON dont la forme dépend de `type`, validé par Zod
/// (cf. `parseAnalysis` dans @portfolio/core) côté Server Action de l'admin.
model Analysis {
  id        String       @id @default(cuid())
  type      AnalysisType @unique // un seul cadre de chaque type pour le profil
  title     String?
  order     Int          @default(0)
  isVisible Boolean      @default(true)
  data      Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// ──────────────────────────────────────────────────────────────────────────
// Blocs de fiche projet (flexible content — payload JSON validé Zod au BO)
// ──────────────────────────────────────────────────────────────────────────

/// Bloc ordonné d'une étude de cas. Le contenu (`data`) est un JSON dont la
/// forme dépend de `type` (phases Gantt, piliers GDD, couches d'archi, scores,
/// recommandations, mesures de sécu…). Validation Zod côté Server Action admin.
model ProjectBlock {
  id        String           @id @default(cuid())
  type      ProjectBlockType
  title     String?
  order     Int              @default(0)
  isVisible Boolean          @default(true)
  data      Json             @default("{}")

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, order])
}

// ──────────────────────────────────────────────────────────────────────────
// Médias (pipeline upload → webp → MinIO)
// ──────────────────────────────────────────────────────────────────────────

/// Chaque image convertie (webp) stockée dans MinIO est tracée ici.
model MediaAsset {
  id           String    @id @default(cuid())
  url          String    @unique
  alt          String?
  originalName String
  mimeType     String
  sizeBytes    Int
  width        Int? // optionnel : vidéos/embeds n'ont pas toujours de dimensions
  height       Int?
  kind         MediaKind @default(IMAGE)
  durationSec  Int? // durée (vidéo)
  provider     String? // fournisseur d'embed (« youtube », « vimeo »…)
  externalUrl  String? // URL source (vidéo hébergée / embed)
  posterUrl    String? // vignette d'aperçu (vidéo)
  createdAt    DateTime  @default(now())

  // Back-relations
  profileAvatar      Profile?       @relation("ProfileAvatar")
  projectCovers      Project[]      @relation("ProjectCover")
  projectImages      ProjectImage[] @relation("ProjectImages")
  articleCovers      Article[]      @relation("ArticleCover")
  projectOgs         Project[]      @relation("ProjectOg")
  articleOgs         Article[]      @relation("ArticleOg")
  siteOg             SiteSettings?  @relation("SiteOg")
  testimonialAvatars Testimonial[]  @relation("TestimonialAvatar")
  eventCovers        Event[]        @relation("EventCover")
  eventMedia         EventMedia[]   @relation("EventMedia")
  articleMedia       ArticleMedia[] @relation("ArticleMedia")
}

// ──────────────────────────────────────────────────────────────────────────
// Agenda & médias (évènements, galeries vidéo/embed, demandes de RDV)
// ──────────────────────────────────────────────────────────────────────────

/// Évènement de l'agenda (meetup, conférence, talk…). Peut être public ou privé,
/// présentiel ou en ligne, avec un lien d'inscription externe. Publication
/// programmable (status SCHEDULED + scheduledAt), comme les actus.
model Event {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String? // markdown
  startAt         DateTime
  endAt           DateTime?
  timezone        String?
  locationName    String?
  address         String?
  city            String?
  isOnline        Boolean         @default(false)
  onlineUrl       String?
  registrationUrl String? // lien d'inscription externe (tiers)
  visibility      EventVisibility @default(PUBLIC)
  status          EventStatus     @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?

  coverId String?
  cover   MediaAsset? @relation("EventCover", fields: [coverId], references: [id], onDelete: SetNull)

  media        EventMedia[]
  article      Article?             @relation("ArticleFromEvent")
  appointments AppointmentRequest[] @relation("AppointmentEvent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startAt])
  @@index([status, startAt])
}

/// Média ordonné d'un évènement (galerie image/vidéo/embed).
model EventMedia {
  id    String @id @default(cuid())
  order Int    @default(0)

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  mediaId String
  media   MediaAsset @relation("EventMedia", fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

/// Média ordonné d'une actu (galerie image/vidéo/embed).
model ArticleMedia {
  id    String @id @default(cuid())
  order Int    @default(0)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  mediaId String
  media   MediaAsset @relation("ArticleMedia", fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// ──────────────────────────────────────────────────────────────────────────
// Assistant IA (config — la clé OpenRouter reste en .env, jamais en DB)
// ──────────────────────────────────────────────────────────────────────────

/// Réglages de l'assistant IA (BO + chatbot public). Pas de secret ici : la clé
/// OpenRouter vit uniquement dans `.env`. Budget mensuel de tokens + garde-fous.
model AiAssistantConfig {
  id                  String   @id @default(cuid())
  model               String   @default("deepseek/deepseek-v4-flash") // slug OpenRouter (peu coûteux), éditable au BO
  assistantName       String   @default("Friday") // prénom de l'e-secrétaire IA (affiché + présentation)
  assistantAvatarUrl  String? // URL d'avatar du chatbot (média public) ; fallback monogramme si vide
  systemPersona       String? // garde-fous : « toujours mettre Yohan en avant, jamais un concurrent »
  isBoAssistEnabled   Boolean  @default(true)
  isPublicChatEnabled Boolean  @default(false)
  monthlyTokenBudget  Int      @default(2000000)
  tokensUsedThisMonth Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────────
// Internationalisation (overlay EN par champ — FR = source de vérité)
// ──────────────────────────────────────────────────────────────────────────

/// Traduction d'un champ d'un enregistrement, par locale. Le FR reste dans les
/// colonnes d'origine ; l'EN est superposé ici (fallback FR si absent). Régénéré
/// par IA à la validation du FR ; `sourceHash` = hash du FR ayant produit la trad.
model Translation {
  id         String   @id @default(cuid())
  model      String // "Profile", "Project", "Article", "Event", "ProjectBlock"…
  recordId   String
  field      String // "bio", "title", "content"…
  locale     String // "en"
  value      String
  isAuto     Boolean  @default(true) // généré par IA (vs édité à la main)
  sourceHash String // hash du texte FR source ayant produit cette traduction
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([model, recordId, field, locale])
  @@index([model, recordId, locale])
}

/// Demande de rendez-vous (formulaire de contact ou chatbot IA → inbox BO).
/// Sécurité : `app_web` peut INSÉRER mais jamais LIRE (comme ContactMessage).
model AppointmentRequest {
  id          String            @id @default(cuid())
  name        String
  firstName   String? // renseigné par la réservation chatbot (identité du visiteur)
  lastName    String?
  email       String
  phone       String? // téléphone du visiteur (réservation chatbot)
  topic       String?
  message     String?
  requestedAt DateTime? // créneau souhaité
  durationMin Int?
  cancelToken String?           @unique // annulation self-service (lien email)
  status      AppointmentStatus @default(PENDING)
  source      AppointmentSource @default(CONTACT)
  ip          String?
  userAgent   String?

  eventId String?
  event   Event?  @relation("AppointmentEvent", fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, requestedAt])
}

/// Indisponibilité déclarée au BO (vacances, blocage ponctuel). Bloque tous les
/// créneaux chevauchant [startAt, endAt] dans le calcul de disponibilité de
/// Friday. Donnée PRIVÉE : `app_web` n'y accède jamais (REVOKE ALL en migration).
model Unavailability {
  id        String   @id @default(cuid())
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startAt, endAt])
}

// ──────────────────────────────────────────────────────────────────────────
// CRM — données PRIVÉES (back office uniquement). `app_web` n'y accède JAMAIS
// (REVOKE ALL dans la migration, comme ContactMessage). Liens cross-domaine
// (projet/témoignage/message) en identifiants souples, résolus par requête au BO.
// ──────────────────────────────────────────────────────────────────────────

enum DealStage {
  PROSPECT
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
}

enum CrmContactStatus {
  LEAD
  ACTIVE
  CUSTOMER
  ARCHIVED
}

enum TaskCategory {
  CRM
  CONTENT
  BILLING
  GENERAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

model Company {
  id        String    @id @default(cuid())
  name      String
  website   String?
  notes     String?
  contacts  Contact[]
  deals     Deal[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
}

model Contact {
  id         String           @id @default(cuid())
  firstName  String
  lastName   String?
  email      String?
  phone      String?
  role       String?
  source     String?
  status     CrmContactStatus @default(LEAD)
  ownerNotes String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Références souples vers les autres domaines (pas de FK — résolues côté BO).
  linkedProjectId  String?
  testimonialId    String?
  contactMessageId String?

  deals      Deal[]
  activities Activity[]
  tasks      Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([companyId])
}

model Deal {
  id              String    @id @default(cuid())
  title           String
  valueCents      Int?
  stage           DealStage @default(PROSPECT)
  probability     Int?
  expectedCloseAt DateTime?

  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  activities Activity[]
  tasks      Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([contactId])
  @@index([companyId])
}

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType @default(NOTE)
  content    String
  occurredAt DateTime     @default(now())

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([dealId])
  @@index([occurredAt])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  category    TaskCategory @default(GENERAL)
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(NORMAL)
  dueAt       DateTime?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueAt])
  @@index([status])
  @@index([category])
  @@index([contactId])
  @@index([dealId])
  @@map("CrmTask")
}
