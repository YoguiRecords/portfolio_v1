# Copier en `.env` (git-ignoré) et renseigner la vraie valeur.
# Dev local : Postgres dédié au portfolio sur le port hôte 5436 (évite 5432/5434 déjà pris).
# Les commandes `prisma` lisent DATABASE_URL depuis l'environnement.
DATABASE_URL="postgresql://portfolio:portfolio_dev@localhost:5436/portfolio?schema=public"
