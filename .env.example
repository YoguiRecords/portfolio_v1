# Copier en `.env` (git-ignoré) pour `docker compose`. Valeurs ci-dessous = DEV uniquement.
# En prod : secrets forts injectés hors-repo (jamais committés).

# ── PostgreSQL ──
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio_dev
POSTGRES_DB=portfolio
# Rôles applicatifs à moindre privilège
WEB_DB_PASSWORD=web_dev
ADMIN_DB_PASSWORD=admin_dev

# ── Back office admin (seed du compte unique) ──
# Identifiants du compte admin créé par `pnpm --filter @portfolio/db db:seed`.
# En prod : mot de passe fort injecté hors-repo (jamais committé). MFA à activer au BO.
ADMIN_EMAIL=admin@yohan-debusscher.com
ADMIN_PASSWORD=admin_dev_change_me

# ── Umami (base + rôle dédiés dans le même Postgres) ──
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami_dev
UMAMI_APP_SECRET=dev_change_me_in_prod

# ── MinIO ──
MINIO_ROOT_USER=portfolio
MINIO_ROOT_PASSWORD=minio_dev_change_me
