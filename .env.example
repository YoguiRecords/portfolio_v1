# Copier en `.env` (git-ignoré) pour `docker compose`. Valeurs ci-dessous = DEV uniquement.
# En prod : secrets forts injectés hors-repo (jamais committés).

# ── PostgreSQL ──
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio_dev
POSTGRES_DB=portfolio
# Rôles applicatifs à moindre privilège
WEB_DB_PASSWORD=web_dev
ADMIN_DB_PASSWORD=admin_dev

# ── Back office admin (seed du compte unique) ──
# Identifiants du compte admin créé par `pnpm --filter @portfolio/db db:seed`.
# En prod : mot de passe fort injecté hors-repo (jamais committé). MFA à activer au BO.
ADMIN_EMAIL=admin@yohan-debusscher.com
ADMIN_PASSWORD=admin_dev_change_me

# ── Umami (base + rôle dédiés dans le même Postgres) ──
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami_dev
UMAMI_APP_SECRET=dev_change_me_in_prod

# ── MinIO ──
MINIO_ROOT_USER=portfolio
MINIO_ROOT_PASSWORD=minio_dev_change_me

# ── IA (OpenRouter) ──
# Clé pour l'assistant de rédaction (BO) et le chatbot public (P14/P15).
# À renseigner dans `.env` UNIQUEMENT (git-ignoré, jamais committé).
# Les tests utilisent un LLM mocké → la CI reste verte sans clé.
OPENROUTER_API_KEY=

# ── Quick login (DEV LOCAL UNIQUEMENT) ──
# Raccourci de connexion au BO (bypass password + MFA). L'image Docker tourne en
# NODE_ENV=production même en local → ce flag runtime dédié le réactive en dev.
# `true` = actif (dev). NE JAMAIS définir en prod (laisser vide / absent = off).
ENABLE_DEV_QUICK_LOGIN=true

# ── Cron (publication programmée) ──
# Secret partageant l'endpoint de bascule des actus/événements programmés (P4/P11).
CRON_SECRET=cron_dev_change_me

# ── Mail & calendrier BO (Microsoft Graph, optionnel) ──
# Non renseigné → le BO tourne en démo (mails) + calendrier du site (agenda + RDV).
# Renseigné → boîte Exchange réelle + calendrier Outlook (cf. docs/technical/INTEGRATIONS.md).
# App-only OAuth2 (client credentials) sur une app Azure AD avec permissions Application :
# Mail.ReadWrite, Mail.Send, Calendars.ReadWrite (+ admin consent).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MAILBOX_USER=contact@yohandebusscher.com
